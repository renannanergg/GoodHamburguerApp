@page "/pedidos/{id:int}"
@using GoodHamburguerApp.Application.DTOs
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="container mt-4">
    <button class="btn btn-link text-decoration-none p-0 mb-3" @onclick="Voltar">
        ⬅ Voltar para a lista
    </button>

    @if (pedido == null)
    {
        <div class="spinner-border text-danger d-block mx-auto" role="status"></div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
                        <h4 class="mb-0">Pedido #@pedido.Id</h4>
                        <span class="badge bg-success">Realizado</span>
                    </div>
                    <div class="card-body">
                        <h5>Itens do Pedido:</h5>
                        <ul class="list-group list-group-flush mb-4">
                            @foreach (var item in pedido.Itens)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <div>
                                        <h6 class="mb-0">@item.Nome</h6>
                                        <small class="text-muted">@item.Categoria</small>
                                    </div>
                                    <span class="fw-bold">@item.Preco.ToString("C")</span>
                                </li>
                            }
                        </ul>

                        <div class="bg-light p-3 rounded">
                            <div class="d-flex justify-content-between">
                                <span>Subtotal:</span>
                                <span>@pedido.Subtotal.ToString("C")</span>
                            </div>
                            <div class="d-flex justify-content-between text-success">
                                <span>Desconto:</span>
                                <span>- @pedido.Desconto.ToString("C")</span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between h4 fw-bold">
                                <span>Total Pago:</span>
                                <span class="text-primary">@pedido.Total.ToString("C")</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-top-0 p-3">
                        <button class="btn btn-outline-danger w-100" @onclick="ConfirmarCancelamento">
                            🗑 Cancelar este Pedido
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private PedidoDTO? pedido;

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetFromJsonAsync<ApiResponse<PedidoDTO>>($"api/v1/pedidos/{Id}");
        pedido = response?.Data;
    }

    private async Task ConfirmarCancelamento()
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"Deseja realmente cancelar o pedido #{Id}?");
        
        if (confirmado)
        {
            var response = await Http.DeleteAsync($"api/v1/pedidos/{Id}");
            
            if (response.IsSuccessStatusCode)
            {
                Nav.NavigateTo("/pedidos");
            }
        }
    }

    private void Voltar() => Nav.NavigateTo("/pedidos");
}
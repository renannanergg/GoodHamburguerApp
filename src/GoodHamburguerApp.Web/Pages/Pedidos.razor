@page "/pedidos"
@using GoodHamburguerApp.Application.DTOs
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📋 Meus Pedidos</h2>
        <a href="cardapio" class="btn btn-danger">Novo Pedido</a>
    </div>

    @if (pedidos == null)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-danger" role="status"></div>
            <p class="mt-2">Carregando seu histórico...</p>
        </div>
    }
    else if (!pedidos.Any())
    {
        <div class="alert alert-info text-center shadow-sm">
            <h4>Nenhum pedido encontrado.</h4>
            <p>Que tal experimentar um de nossos burgers agora?</p>
            <a href="cardapio" class="btn btn-primary mt-2">Ir para o Cardápio</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle bg-white">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Itens</th>
                        <th class="text-end">Total</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in pedidos)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">#@pedido.Id</span></td>
                            <td>@pedido.Itens.Count item(ns)</td>
                            <td class="text-end fw-bold">@pedido.Total.ToString("C")</td>
                            <td class="text-center">
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => VerDetalhes(pedido.Id)">
                                    🔍 Ver Detalhes
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-center align-items-center mt-4 gap-3">
            <button class="btn btn-outline-dark" @onclick="PaginaAnterior" disabled="@(currentOffset == 0)">
                Anterior
            </button>
            <span class="text-muted small">Exibindo de @(currentOffset + 1) até @(Math.Min(currentOffset + currentLimit, totalCount)) de @totalCount</span>
            <button class="btn btn-outline-dark" @onclick="ProximaPagina" disabled="@(currentOffset + currentLimit >= totalCount)">
                Próxima
            </button>
        </div>
    }
</div>

@code {
    private List<PedidoDTO>? pedidos;
    private int currentOffset = 0;
    private int currentLimit = 10;
    private int totalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await CarregarPedidos();
    }

    private async Task CarregarPedidos()
    {
        pedidos = null;
        try
        {
            var url = $"api/v1/pedidos?offset={currentOffset}&limit={currentLimit}";
            var response = await Http.GetFromJsonAsync<ApiResponse<PagedData<PedidoDTO>>>(url);

            if (response?.Data != null)
            {
                pedidos = response.Data.Items.ToList();
                totalCount = response.Data.TotalCount;
            }
        }
        catch (Exception)
        {
            pedidos = new(); 
        }
    }

    private async Task ProximaPagina()
    {
        currentOffset += currentLimit;
        await CarregarPedidos();
    }

    private async Task PaginaAnterior()
    {
        currentOffset = Math.Max(0, currentOffset - currentLimit);
        await CarregarPedidos();
    }

    private void VerDetalhes(int id) => Nav.NavigateTo($"/pedidos/{id}");
}